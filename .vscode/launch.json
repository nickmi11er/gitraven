{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run GitRaven Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--disable-extensions", "--extensionDevelopmentPath=${workspaceFolder}"],
      "outFiles": ["${workspaceFolder}/dist/**/*.cjs"],
      "preLaunchTask": "npm: build"
    }
  ]
}
