{
  "name": "gitraven",
  "displayName": "GitRaven",
  "description": "A git client for VS Code: commit graph, multi-repository support, and interactive rebase. Fetches your history like Odin's ravens.",
  "version": "0.1.3",
  "publisher": "mi11er",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nickmi11er/gitraven.git"
  },
  "bugs": {
    "url": "https://github.com/nickmi11er/gitraven/issues"
  },
  "homepage": "https://github.com/nickmi11er/gitraven#readme",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "SCM Providers"
  ],
  "keywords": [
    "git",
    "git client",
    "git gui",
    "git history",
    "git graph",
    "git log",
    "commit",
    "commit graph",
    "branch",
    "merge",
    "rebase",
    "interactive rebase",
    "diff",
    "stash",
    "repository",
    "version control",
    "source control",
    "scm",
    "history",
    "raven"
  ],
  "main": "./dist/extension.cjs",
  "icon": "media/icon.png",
  "activationEvents": [
    "onView:gitraven.logView",
    "workspaceContains:**/.git"
  ],
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "gitraven",
          "title": "Git",
          "icon": "media/activitybar.svg"
        }
      ],
      "activitybar": [
        {
          "id": "gitraven-commit",
          "title": "Commit",
          "icon": "media/activitybar.svg"
        }
      ]
    },
    "views": {
      "gitraven": [
        {
          "type": "webview",
          "id": "gitraven.logView",
          "name": "Log",
          "contextualTitle": "Git"
        }
      ],
      "gitraven-commit": [
        {
          "type": "webview",
          "id": "gitraven.commitView",
          "name": "Commit",
          "contextualTitle": "Commit"
        }
      ]
    },
    "commands": [
      {
        "command": "gitraven.refresh",
        "title": "Refresh",
        "category": "GitRaven",
        "icon": "$(refresh)"
      },
      {
        "command": "gitraven.selectRepositories",
        "title": "Select Repositories…",
        "category": "GitRaven",
        "icon": "$(repo)"
      },
      {
        "command": "gitraven.fetch",
        "title": "Fetch",
        "category": "GitRaven",
        "icon": "$(cloud-download)"
      },
      {
        "command": "gitraven.pull",
        "title": "Pull",
        "category": "GitRaven",
        "icon": "$(arrow-down)"
      },
      {
        "command": "gitraven.push",
        "title": "Push",
        "category": "GitRaven",
        "icon": "$(arrow-up)"
      },
      {
        "command": "gitraven.commit",
        "title": "Commit…",
        "category": "GitRaven"
      },
      {
        "command": "gitraven.createBranch",
        "title": "New Branch…",
        "category": "GitRaven"
      },
      {
        "command": "gitraven.checkout",
        "title": "Checkout…",
        "category": "GitRaven"
      },
      {
        "command": "gitraven.startInteractiveRebase",
        "title": "Interactive Rebase…",
        "category": "GitRaven"
      },
      {
        "command": "gitraven.rebaseContinue",
        "title": "Continue Rebase",
        "category": "GitRaven"
      },
      {
        "command": "gitraven.rebaseAbort",
        "title": "Abort Rebase",
        "category": "GitRaven"
      },
      {
        "command": "gitraven.annotateWithBlame",
        "title": "Annotate with Git Blame",
        "category": "GitRaven"
      },
      {
        "command": "gitraven.clearBlame",
        "title": "Clear Blame Annotations",
        "category": "GitRaven"
      },
      {
        "command": "gitraven.showFileHistory",
        "title": "Show History",
        "category": "GitRaven"
      },
      {
        "command": "gitraven.showSelectionHistory",
        "title": "Show History for Selection",
        "category": "GitRaven"
      },
      {
        "command": "gitraven.compareWithRef",
        "title": "Compare with Revision or Branch…",
        "category": "GitRaven"
      },
      {
        "command": "gitraven.openLineOnRemote",
        "title": "Open Line on Remote",
        "category": "GitRaven"
      },
      {
        "command": "gitraven.copyLinePermalink",
        "title": "Copy Line Permalink",
        "category": "GitRaven"
      },
      {
        "command": "gitraven.undoLastOperation",
        "title": "Undo Last Git Operation…",
        "category": "GitRaven"
      },
      {
        "command": "gitraven.showOperationJournal",
        "title": "Git Operation Journal…",
        "category": "GitRaven"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "gitraven.fetch",
          "when": "view == gitraven.logView",
          "group": "navigation@1"
        },
        {
          "command": "gitraven.pull",
          "when": "view == gitraven.logView",
          "group": "navigation@2"
        },
        {
          "command": "gitraven.push",
          "when": "view == gitraven.logView",
          "group": "navigation@3"
        },
        {
          "command": "gitraven.refresh",
          "when": "view == gitraven.logView",
          "group": "navigation@4"
        },
        {
          "command": "gitraven.selectRepositories",
          "when": "view == gitraven.logView",
          "group": "navigation@5"
        },
        {
          "command": "gitraven.undoLastOperation",
          "when": "view == gitraven.logView",
          "group": "journal@1"
        },
        {
          "command": "gitraven.showOperationJournal",
          "when": "view == gitraven.logView",
          "group": "journal@2"
        }
      ],
      "explorer/context": [
        {
          "command": "gitraven.showFileHistory",
          "when": "gitraven.hasRepository && resourceScheme == file",
          "group": "4_timeline@10"
        }
      ],
      "editor/context": [
        {
          "command": "gitraven.showFileHistory",
          "when": "gitraven.hasRepository && resourceScheme == file && !editorHasSelection",
          "group": "gitraven@1"
        },
        {
          "command": "gitraven.showSelectionHistory",
          "when": "gitraven.hasRepository && resourceScheme == file && editorHasSelection",
          "group": "gitraven@1"
        },
        {
          "command": "gitraven.compareWithRef",
          "when": "gitraven.hasRepository && resourceScheme == file",
          "group": "gitraven@2"
        },
        {
          "command": "gitraven.openLineOnRemote",
          "when": "gitraven.hasRepository && (resourceScheme == file || resourceScheme == gitraven-git)",
          "group": "gitraven@3"
        },
        {
          "command": "gitraven.copyLinePermalink",
          "when": "gitraven.hasRepository && (resourceScheme == file || resourceScheme == gitraven-git)",
          "group": "gitraven@4"
        }
      ],
      "editor/lineNumber/context": [
        {
          "command": "gitraven.annotateWithBlame",
          "when": "gitraven.hasRepository && (resourceScheme == file || resourceScheme == gitraven-git) && !gitraven.blameActive",
          "group": "gitraven@1"
        },
        {
          "command": "gitraven.clearBlame",
          "when": "gitraven.blameActive",
          "group": "gitraven@1"
        }
      ],
      "commandPalette": [
        {
          "command": "gitraven.commit",
          "when": "gitraven.hasRepository"
        },
        {
          "command": "gitraven.createBranch",
          "when": "gitraven.hasRepository"
        },
        {
          "command": "gitraven.checkout",
          "when": "gitraven.hasRepository"
        },
        {
          "command": "gitraven.startInteractiveRebase",
          "when": "gitraven.hasRepository"
        },
        {
          "command": "gitraven.rebaseContinue",
          "when": "gitraven.isRebasing"
        },
        {
          "command": "gitraven.rebaseAbort",
          "when": "gitraven.isRebasing"
        },
        {
          "command": "gitraven.annotateWithBlame",
          "when": "gitraven.hasRepository"
        },
        {
          "command": "gitraven.clearBlame",
          "when": "gitraven.blameActive"
        },
        {
          "command": "gitraven.showFileHistory",
          "when": "gitraven.hasRepository"
        },
        {
          "command": "gitraven.showSelectionHistory",
          "when": "gitraven.hasRepository && editorHasSelection"
        },
        {
          "command": "gitraven.compareWithRef",
          "when": "gitraven.hasRepository"
        },
        {
          "command": "gitraven.openLineOnRemote",
          "when": "gitraven.hasRepository"
        },
        {
          "command": "gitraven.copyLinePermalink",
          "when": "gitraven.hasRepository"
        },
        {
          "command": "gitraven.undoLastOperation",
          "when": "gitraven.hasRepository"
        },
        {
          "command": "gitraven.showOperationJournal",
          "when": "gitraven.hasRepository"
        }
      ]
    },
    "configuration": {
      "title": "GitRaven",
      "properties": {
        "gitraven.gitPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the git executable. Leave empty to auto-detect."
        },
        "gitraven.log.maxCommits": {
          "type": "number",
          "default": 5000,
          "description": "Maximum number of commits loaded per page in the log."
        },
        "gitraven.repositories.autoDiscover": {
          "type": "boolean",
          "default": true,
          "description": "Automatically discover git repositories in the workspace, including nested ones."
        },
        "gitraven.repositories.scanDepth": {
          "type": "number",
          "default": 3,
          "description": "How many directory levels deep to scan for nested repositories."
        },
        "gitraven.repositories.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/node_modules/**",
            "**/.venv/**",
            "**/vendor/**"
          ],
          "description": "Glob patterns excluded from repository discovery."
        },
        "gitraven.graph.rowHeight": {
          "type": "number",
          "default": 24,
          "description": "Height in pixels of a single row in the commit graph."
        },
        "gitraven.graph.laneWidth": {
          "type": "number",
          "default": 14,
          "description": "Width in pixels of a single lane in the commit graph."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs --production",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc -p tsconfig.extension.json --noEmit && tsc -p tsconfig.webview.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext ts,tsx",
    "vscode:prepublish": "npm run build",
    "version": "node scripts/stamp-changelog.mjs && git add CHANGELOG.md"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@vscode/codicons": "^0.0.45",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-window": "^1.8.10",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/react-window": "^1.8.8",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.23.0",
    "jsdom": "^27.0.1",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
